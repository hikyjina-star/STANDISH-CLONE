{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/www.standish.ca/en/index.html"
    },
    {
      "source": "/am/",
      "destination": "/www.standish.ca/am/index.html"
    },
    {
      "source": "/am/:path*",
      "destination": "/www.standish.ca/am/:path*"
    },
    {
      "source": "/en/:path*",
      "destination": "/www.standish.ca/en/:path*"
    }
  ]
}
